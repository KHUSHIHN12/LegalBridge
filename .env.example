# LegalBridge local environment example.
# Copy this file to .env and replace the values before running locally.
# Never commit the real .env file to GitHub.

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-strong-random-flask-secret-key

# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-a-different-strong-random-jwt-secret

# For local development use development. For deployed servers use production.
FLASK_ENV=development

# Keep false in production.
DEBUG=false

# Local HashiCorp Vault demo settings.
# Docker Compose uses http://vault:8200 inside containers.
# Host scripts use http://localhost:8200 from your machine.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=legalbridge-root-token
